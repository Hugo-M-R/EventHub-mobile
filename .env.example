# Copie para .env e preencha com os dados do Firebase Console.
# Projeto: Configurações → Geral → Seus apps (Web e Android)
#
# Console: https://console.firebase.google.com/project/eventhub-6f78e
# 1) Authentication → Sign-in method → E-mail/senha + Google (ativar)
# 2) Authentication → Settings → Authorized domains → incluir localhost
# 3) Firestore → criar banco (modo produção) → publicar firestore.rules
#    (npm i -g firebase-tools && firebase login && firebase deploy --only firestore:rules)
#
# Use appId separado por plataforma (recomendado):
FIREBASE_API_KEY=sua_api_key
FIREBASE_AUTH_DOMAIN=eventhub-6f78e.firebaseapp.com
FIREBASE_PROJECT_ID=eventhub-6f78e
FIREBASE_STORAGE_BUCKET=eventhub-6f78e.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=801727241083
FIREBASE_WEB_APP_ID=1:801727241083:web:SEU_APP_ID_WEB
FIREBASE_ANDROID_APP_ID=1:801727241083:android:SEU_APP_ID_ANDROID
# Fallback legado (opcional se as linhas acima estiverem preenchidas)
FIREBASE_APP_ID=1:801727241083:web:SEU_APP_ID_WEB
# Opcional (Analytics, app Web)
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

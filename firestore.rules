rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      return request.auth.token.email.matches('.*@souunit\\.com\\.br$');
    }

    function isEventOwner() {
      return resource.data.createdBy == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated() && isInstitutionalEmail();

      allow create: if isAuthenticated()
        && isInstitutionalEmail()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.usuario_logado == request.auth.token.email;

      allow update: if isAuthenticated()
        && isInstitutionalEmail()
        && isEventOwner()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.usuario_logado == resource.data.usuario_logado;

      allow delete: if isAuthenticated()
        && isInstitutionalEmail()
        && isEventOwner();
    }

    match /users/{userId}/saved_events/{eventId} {
      allow read: if isAuthenticated()
        && isInstitutionalEmail()
        && request.auth.uid == userId;

      allow create: if isAuthenticated()
        && isInstitutionalEmail()
        && request.auth.uid == userId
        && request.resource.data.usuario_logado == request.auth.token.email
        && request.resource.data.eventId == eventId;

      allow delete: if isAuthenticated()
        && isInstitutionalEmail()
        && request.auth.uid == userId;
    }
  }
}
